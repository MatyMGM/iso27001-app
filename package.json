{
  "name": "iso27001-assessment-backend",
  "version": "0.1.0",
  "description": "ISO 27001:2022 assessment backend (NestJS + Prisma + PostgreSQL)",
  "private": true,
  "scripts": {
    "build": "node node_modules/@nestjs/cli/bin/nest.js build",
    "start": "node node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "node node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:prod": "node dist/main",
    "prisma:generate": "node node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node node_modules/prisma/build/index.js migrate dev",
    "prisma:deploy": "node node_modules/prisma/build/index.js migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "db:reset": "node node_modules/prisma/build/index.js migrate reset --force"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@prisma/client": "^5.20.0",
    "prisma": "^5.20.0",
    "@sparticuz/chromium": "^148.0.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "groq-sdk": "^1.1.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "puppeteer-core": "^24.42.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/passport-jwt": "^4.0.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}
