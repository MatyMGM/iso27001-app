generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssessmentStatus {
  draft
  completed
  analyzed
}

enum AssessmentType {
  free
  profesional
  premium
}

enum AssessmentFramework {
  iso27001
  soc2
  cis
}

enum AnswerValue {
  yes
  partial
  no
  na
}

enum Criticality {
  alta
  media
  baja
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  companies Company[]
}

model Company {
  id          String       @id @default(cuid())
  name        String
  industry    String?
  size        String?
  userId      String?
  user        User?        @relation(fields: [userId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assessments Assessment[]

  @@index([userId])
}

model Assessment {
  id               String              @id @default(cuid())
  companyId        String
  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status           AssessmentStatus    @default(draft)
  type             AssessmentType      @default(premium)
  framework        AssessmentFramework @default(iso27001)
  aiReport         Json?
  benchmarkConsent Boolean?
  computedScore    Float?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  answers          Answer[]

  @@index([companyId])
  @@index([benchmarkConsent])
  @@index([framework])
}

model Question {
  id           String              @id @default(cuid())
  controlRef   String              @unique
  controlName  String
  domain       String
  criticality  Criticality
  questionText String
  framework    AssessmentFramework @default(iso27001)
  createdAt    DateTime            @default(now())
  answers      Answer[]

  @@index([domain])
  @@index([framework])
}

model Answer {
  id           String      @id @default(cuid())
  assessmentId String
  assessment   Assessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value        AnswerValue
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
  @@index([questionId])
}
